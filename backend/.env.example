# Database (comment out to use SQLite for local dev without Docker)
# DATABASE_URL=postgresql+psycopg://securemoney:securemoney_pass@postgres:5432/securemoney

# MASTER_KEY - development only. In production, use Vault/KMS.
MASTER_KEY=dev_master_key_32_bytes_long_123456

# JWT key paths (mount your secrets in production)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# Redis
REDIS_URL=redis://redis:6379/0

# SendGrid (for email OTP)
SENDGRID_API_KEY=
# MAIL_FROM=noreply@securemoney.co.tz

# Other
FLASK_ENV=development
SENTRY_DSN=
